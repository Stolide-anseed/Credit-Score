cat > .gitignore << 'EOF'
# Python cache files
__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/

# Data files (too large for Git)
*.csv
*.parquet

# Environment secrets (NEVER commit these)
.env
*.secret

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Log files
*.log
logs/
EOF